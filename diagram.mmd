flowchart TD
    A([User Preferences<br/>genre · mood · energy · acoustic]) --> B[For each song in catalog<br/>compute a match score]

    subgraph Scoring_Logic [Scoring Logic]
        direction TB
        B --> C{Genre match?}
        
        C -- Yes --> D[+0.30]
        C -- No --> E[+0.00]

        D --> F{Mood match?}
        E --> F

        F -- Yes --> G[+0.25]
        F -- No --> H[+0.00]
        
        G --> I[Energy closeness * 0.25]
        H --> I
    end

    subgraph Final_Refinement [Final Refinement]
        I --> J[Acoustic fit * 0.20]
        J --> K[Total score 0.0 to 1.0]
    end

    subgraph Output [Recommendations]
        K --> L[Rank all songs by score]
        L --> M([Top K Recommendations])
    end

    